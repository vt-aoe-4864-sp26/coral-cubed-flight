# --- CORE SUBSYSTEMS ---
CONFIG_GPIO=y
CONFIG_PINCTRL=y
CONFIG_CLOCK_CONTROL=y

# --- SERIAL & CONSOLE ---
CONFIG_SERIAL=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y
CONFIG_UART_INTERRUPT_DRIVEN=y
CONFIG_UART_LINE_CTRL=y

# --- USB VIRTUAL COM PORT (CDC ACM) ---
CONFIG_USB_DEVICE_STACK=y
CONFIG_USB_DEVICE_PRODUCT="Coral CDH Board"
CONFIG_USB_DEVICE_VID=0x1209
CONFIG_USB_DEVICE_PID=0x0001
CONFIG_USB_DEVICE_INITIALIZE_AT_BOOT=y

# (Optional but recommended) Wait for USB connection before booting main()
# This ensures you don't miss early printk() messages before opening Putty/Minicom
# CONFIG_USB_DEVICE_INITIALIZE_AT_BOOT is usually enough, but sometimes apps need a delay.