
# --- CORE HARDWARE ---

CONFIG_GPIO=y
CONFIG_PINCTRL=y
CONFIG_CLOCK_CONTROL=y

## Keeps the SWD debug pins alive even if the CPU idles

CONFIG_DEBUG=y

## Prevents power management from shutting down clocks while debugging

CONFIG_PM=n

## Prevents the hardware watchdog from infinite-looping an empty app

CONFIG_WATCHDOG=n

## --- BASE SERIAL & USB HARDWARE ---

CONFIG_SERIAL=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=n
CONFIG_UART_LINE_CTRL=y
CONFIG_USB_DEVICE_STACK=y
CONFIG_USB_CDC_ACM=y

## --- STABILITY ---

CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=y
